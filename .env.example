# Copy to .env and adjust before running docker-compose.

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fraudnet_dev_pw

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Redis (cache + Celery broker uses /1, results /2)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# PostgreSQL
POSTGRES_PASSWORD=fraudnet_dev_pw
DATABASE_URL=postgresql+asyncpg://fraudnet:fraudnet_dev_pw@postgres:5432/fraudnet
DATABASE_URL_SYNC=postgresql://fraudnet:fraudnet_dev_pw@postgres:5432/fraudnet

# MinIO
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=fraudnet
MINIO_SECRET_KEY=fraudnet_dev_pw
MINIO_BUCKET=fraudnet-evidence

# Auth
JWT_SECRET=please-change-me-in-prod-this-is-a-dev-only-default
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=480

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:8080,http://localhost:3000

# Runtime
LOG_LEVEL=INFO
ENVIRONMENT=development
